<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hospital.auth.mapper.PermissionMapper">

    <!-- ==================== 结果映射 ==================== -->

    <resultMap id="BaseResultMap" type="com.hospital.auth.entity.Permission">
        <id column="id" property="id"/>
        <result column="perm_code" property="permCode"/>
        <result column="perm_name" property="permName"/>
        <result column="perm_type" property="permType"/>
        <result column="parent_id" property="parentId"/>
        <result column="path" property="path"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <!-- ==================== SQL ==================== -->

    <select id="findByRoleIds" resultMap="BaseResultMap">
        SELECT DISTINCT p.id, p.perm_code, p.perm_name, p.perm_type,
               p.parent_id, p.path, p.sort_order, p.status, p.create_time, p.update_time
        FROM permission p
        INNER JOIN role_permission rp ON p.id = rp.permission_id
        WHERE rp.role_id IN
        <foreach collection="roleIds" item="roleId" open="(" separator="," close=")">
            #{roleId}
        </foreach>
        AND p.status = 1
        ORDER BY p.sort_order
    </select>

</mapper>
