<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hospital.patient.mapper.AllergyMapper">

    <resultMap id="BaseResultMap" type="com.hospital.patient.entity.Allergy">
        <id column="id" property="id"/>
        <result column="patient_id" property="patientId"/>
        <result column="allergen" property="allergen"/>
        <result column="reaction_type" property="reactionType"/>
        <result column="severity" property="severity"/>
        <result column="source" property="source"/>
        <result column="source_doctor_id" property="sourceDoctorId"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="selectByPatientId" resultMap="BaseResultMap">
        SELECT * FROM allergy WHERE patient_id = #{patientId} ORDER BY create_time DESC
    </select>

    <insert id="insert" parameterType="com.hospital.patient.entity.Allergy"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO allergy (patient_id, allergen, reaction_type, severity,
                             source, source_doctor_id, create_time)
        VALUES (#{patientId}, #{allergen}, #{reactionType}, #{severity},
                #{source}, #{sourceDoctorId}, NOW())
    </insert>

    <delete id="deleteById">
        DELETE FROM allergy WHERE id = #{id} AND patient_id = #{patientId}
    </delete>

</mapper>
